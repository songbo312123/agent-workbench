{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/refs/heads/main/tauri/src-tauri/gen/schemas/desktop-schema.json",
  "productName": "Agent Workbench",
  "version": "0.1.0",
  "identifier": "com.agent-workbench.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Workbench",
        "width": 1440,
        "height": 900,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
